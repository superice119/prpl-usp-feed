From 7554be5b38b358708c4b42ee804cdfbbf4b36d0c Mon Sep 17 00:00:00 2001
From: Piotr Nakraszewicz <piotr.nakraszewicz@consult.red>
Date: Wed, 15 Apr 2026 16:50:42 +0200
Subject: [PATCH] Implement load_agent_cert_cb vendor hook

load_agent_cert_cb is a vendor hook (callback) already declared in
obuspa. When it is registered, it is called to load the device private
key and device certificate into the provided openssl context. It is
called by obuspa core to initialize the openssl context of all MTP
connections.

If obuspa is given the following two environment variables:
- CertificateURI
- PrivateKeyURI
register the hook, and when the hook is called, extract their values and
load the given security credentials.
Add support for pkcs#11 private key URI as well as file path.
---
 src/vendor/vendor.c | 95 +++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 95 insertions(+)

diff --git a/src/vendor/vendor.c b/src/vendor/vendor.c
index 594ff97..b7762ef 100644
--- a/src/vendor/vendor.c
+++ b/src/vendor/vendor.c
@@ -44,6 +44,7 @@
 #include <stdlib.h>
 #include <stdbool.h>
 #include <string.h>
+#include <openssl/engine.h>
 
 #include "usp_err_codes.h"
 #include "vendor_defs.h"
@@ -90,6 +91,99 @@ static bool can_mtp_connect(void)
    return true;
 }
 
+static int load_agent_cert(SSL_CTX *ctx)
+{
+    int err = USP_ERR_OK;
+    const char *certificate_uri = getenv("CertificateURI");
+    const char *privatekey_uri = getenv("PrivateKeyURI");
+
+    // Load device certificate
+    if (certificate_uri && certificate_uri[0] != '\0')
+    {
+        if (SSL_CTX_use_certificate_file(ctx, certificate_uri, SSL_FILETYPE_PEM) != 1)
+        {
+            USP_LOG_Warning("%s: Failed to load device certificate from %s", __FUNCTION__, certificate_uri);
+            err = USP_ERR_INTERNAL_ERROR;
+        }
+        else
+        {
+            USP_LOG_Info("%s: Loaded device certificate from %s", __FUNCTION__, certificate_uri);
+        }
+    }
+
+    // Load private key
+    if (privatekey_uri && privatekey_uri[0] != '\0')
+    {
+        //Check if the private key URI is in PKCS#11 format
+        if (strncmp(privatekey_uri, "pkcs11:", 7) == 0)
+        {
+// To allow the use of OpenSSL engine APIs until OpenSSL providers are supported across prplOS
+#pragma GCC diagnostic push
+#pragma GCC diagnostic ignored "-Wdeprecated-declarations"
+            ENGINE *e = ENGINE_by_id("pkcs11");
+            if (e == NULL)
+            {
+                USP_LOG_Warning("%s: Failed to get PKCS#11 engine", __FUNCTION__);
+                err = USP_ERR_INTERNAL_ERROR;
+            }
+            else
+            {
+                EVP_PKEY *pkey = ENGINE_load_private_key(e, privatekey_uri, NULL, NULL);
+                if (pkey)
+                {
+                    if (SSL_CTX_use_PrivateKey(ctx, pkey) != 1)
+                    {
+                        char buf[256];
+                        unsigned long err = ERR_get_error();
+                        ERR_error_string_n(err, buf, sizeof(buf));
+                        USP_LOG_Warning("%s: Failed to load private key from PKCS#11 URI %s (OpenSSL error: %s)", __FUNCTION__, privatekey_uri, buf);
+                        err = USP_ERR_INTERNAL_ERROR;
+                    }
+                    else
+                    {
+                        USP_LOG_Info("%s: Loaded private key from PKCS#11 URI %s", __FUNCTION__, privatekey_uri);
+                    }
+                    EVP_PKEY_free(pkey);
+                }
+                else
+                {
+                    USP_LOG_Warning("%s: ENGINE_load_private_key failed for PKCS#11 URI %s", __FUNCTION__, privatekey_uri);
+                    err = USP_ERR_INTERNAL_ERROR;
+                }
+                ENGINE_free(e);
+            }
+#pragma GCC diagnostic pop
+        }
+        else
+        {
+            // If the private key is specified as a file path
+            if (SSL_CTX_use_PrivateKey_file(ctx, privatekey_uri, SSL_FILETYPE_PEM) != 1)
+            {
+                USP_LOG_Warning("%s: Failed to load private key from %s", __FUNCTION__, privatekey_uri);
+                err = USP_ERR_INTERNAL_ERROR;
+            }
+            else
+            {
+                USP_LOG_Info("%s: Loaded private key from %s", __FUNCTION__, privatekey_uri);
+            }
+        }
+    }
+
+    return err;
+}
+
+static void register_load_agent_cert_cb(vendor_hook_cb_t *callbacks)
+{
+    const char *certificate_uri = getenv("CertificateURI");
+    const char *privatekey_uri = getenv("PrivateKeyURI");
+
+    if (certificate_uri != NULL && certificate_uri[0] != '\0' &&
+        privatekey_uri != NULL && privatekey_uri[0] != '\0')
+    {
+        USP_LOG_Info("%s: registering", __FUNCTION__);
+        callbacks->load_agent_cert_cb = load_agent_cert;
+    }
+}
 
 /*********************************************************************//**
 **
@@ -107,6 +201,7 @@ int VENDOR_Init(void)
     vendor_hook_cb_t callbacks;
     memset(&callbacks, 0, sizeof(callbacks));
     callbacks.can_mtp_connect_cb = can_mtp_connect;
+    register_load_agent_cert_cb(&callbacks);
     USP_REGISTER_CoreVendorHooks(&callbacks);
 
     return USP_ERR_OK;
-- 
2.43.0

